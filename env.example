GOOGLE_SHEET_ID=<id-da-planilha>
LOGIN_SHEET_NAME=Base de dados
SHEET_AB1_PESQUISA=AT. 1
SHEET_AB1_ARTIGO=AT. 2
SHEET_AB1_LISTA=AT. 3
SHEET_AB1_PROVA=Notas AB1
SHEET_AB2_LISTA=AT. 4
SHEET_AB2_PROJETO=Projeto AB2
SESSION_SECRET=use-uma-chave-forte-com-mais-de-32-caracteres
COOKIE_SECURE=false
DOCS_USERNAME=adão
DOCS_PASSWORD=primeiro
GOOGLE_SERVICE_ACCOUNT_FILE=./service-account.local.json

# Frontend - deixe vazio quando a API estiver no mesmo projeto Vercel.
# Use apenas se o backend estiver em outro dominio.
# VITE_API_BASE=https://seu-backend.example.com

# Em producao/Vercel, configure estas variaveis no painel do projeto.
# COOKIE_SECURE=true
# GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=<base64-da-credencial-json>
# GOOGLE_SERVICE_ACCOUNT_FILE deve ficar apenas no desenvolvimento local.
