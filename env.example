# Template seguro. Nao coloque valores reais neste arquivo e nunca versione `.env`.

# Backend obrigatorio
# V1/legado: um unico arquivo.
GOOGLE_SHEET_ID=
# V2: varios arquivos separados por virgula, ponto e virgula ou quebra de linha.
GOOGLE_SHEET_IDS=
SHEETS_RUNTIME_VERSION=v1
GOOGLE_SHEET_METADATA_KEY=dbback_schema
GOOGLE_SHEET_METADATA_VALUE=v2
LOGIN_SHEET_NAME=Base de dados
SHEET_AB1_PESQUISA=AT. 1
SHEET_AB1_ARTIGO=AT. 2
SHEET_AB1_LISTA=AT. 3
SHEET_AB1_PROVA=Notas AB1
SHEET_AB2_LISTA=AT. 4
SHEET_AB2_PROJETO=Projeto AB2
SESSION_SECRET=
COOKIE_SECURE=true
DOCS_USERNAME=
DOCS_PASSWORD=

# Credencial Google obrigatoria. Use exatamente uma opcao.
# Recomendado no Vercel/producao:
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
# Apenas desenvolvimento local:
# GOOGLE_SERVICE_ACCOUNT_FILE=./service-account.local.json
# Alternativa local, prefira base64 para evitar JSON multilinha:
# GOOGLE_SERVICE_ACCOUNT_JSON=

# Desenvolvimento local
PORT=3000

# Frontend opcional. Deixe vazio quando frontend e /api/* estiverem no mesmo projeto Vercel.
VITE_API_BASE=
