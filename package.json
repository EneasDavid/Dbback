{
  "name": "@eneasdavid/dbback",
  "version": "1.0.0",
  "description": "Consulta autenticada de notas e feedbacks com Go, React e Google Sheets.",
  "private": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EneasDavid/Dbback.git"
  },
  "bugs": {
    "url": "https://github.com/EneasDavid/Dbback/issues"
  },
  "homepage": "https://github.com/EneasDavid/Dbback#readme",
  "license": "UNLICENSED",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "files": [
    "api",
    "cmd",
    "dist",
    "docs",
    "pkg",
    "src",
    "env.example",
    "go.mod",
    "go.sum",
    "index.html",
    "README.md",
    "tsconfig.json",
    "tsconfig.app.json",
    "vite.config.ts"
  ],
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:full": "npm run build && go run ./cmd/dev",
    "production:full": "npm run build && go run ./cmd/dev",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "package": "npm pack",
    "package:dry-run": "npm pack --dry-run",
    "prepack": "npm run build",
    "preview": "vite preview --host 0.0.0.0",
    "quality": "npm run lint && npm run build"
  },
  "dependencies": {
    "@vercel/speed-insights": "^2.0.0",
    "@vitejs/plugin-react": "^4.5.0",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "vite": "^6.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.27.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "sass": "^1.100.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.60.0"
  }
}
